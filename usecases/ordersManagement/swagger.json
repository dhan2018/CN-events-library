    "/events/order-confirmed": {
      "post": {
        "summary": "Order Confirmed Event",
        "description": "Publishes an order confirmation event to Kafka topic: order-confirmed",
        "tags": ["Order Events"],
        "intent": "Order Management",
        "sub_intent": "Confirm Order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
