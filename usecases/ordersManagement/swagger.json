{
  "openapi": "3.0.3",
  "info": {
    "title": "Order Management Events API",
    "description": "Event schemas for order lifecycle management in a Kafka-based event-driven system for ISP services",
    "version": "1.1.0"
  },
  "components": {
    "schemas": {
      "Price": {
        "type": "object",
        "description": "Price information",
        "properties": {
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "amount": {
            "type": "number",
            "description": "The numeric value of the price"
          },
          "currency": {
            "type": "string",
            "default": "USD",
            "description": "The currency code (e.g., USD)"
          }
        },
        "required": ["orgId", "amount", "currency"]
      },
      "OrderLineItem": {
        "type": "object",
        "description": "Individual line item in an order",
        "properties": {
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "itemId": {
            "type": "string",
            "description": "A unique identifier for this line item"
          },
          "productType": {
            "type": "string",
            "enum": ["Data", "Voice", "Video", "AddOn"],
            "description": "The category of the product"
          },
          "productName": {
            "type": "string",
            "description": "The commercial name of the product (e.g., 'Fiber Internet 1 Gig')"
          },
          "monthlyPrice": {
            "$ref": "#/components/schemas/Price"
          },
          "oneTimePrice": {
            "$ref": "#/components/schemas/Price"
          }
        },
        "required": ["orgId", "itemId", "productType", "productName"]
      },
      "OrderCreatedEvent": {
        "type": "object",
        "description": "Event fired when a customer submits a new order for activation",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier for this event"
          },
          "eventType": {
            "type": "string",
            "default": "ORDER_CREATED",
            "description": "The type of the event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the event was emitted"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "orderId": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier for this order"
          },
          "orderStatus": {
            "type": "string",
            "default": "New",
            "description": "The current status of the order (e.g., New)"
          },
          "orderType": {
            "type": "string",
            "description": "The type of order (e.g., New, Transfer, Upgrade)"
          },
          "orderCreatedTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the order was created"
          },
          "CustomerDetails": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/CustomerDetails"
          },
          "Address": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/Address"
          },
          "serviceAddress": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/Address",
            "description": "The service installation address (alias for Address)"
          },
          "billingAddress": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/billingAddress"
          },
          "Appointment": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/Appointment"
          },
          "lineItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderLineItem"
            }
          },
          "totalMonthlyPrice": {
            "$ref": "#/components/schemas/Price"
          },
          "totalOneTimePrice": {
            "$ref": "#/components/schemas/Price"
          }
        },
        "required": [
          "eventId",
          "eventType",
          "eventTimestamp",
          "orgId",
          "orderId",
          "orderCreatedTimestamp",
          "CustomerDetails",
          "Address",
          "billingAddress",
          "Appointment",
          "lineItems"
        ]
      },
      "OrderSavedEvent": {
        "type": "object",
        "description": "Event fired when a customer saves a draft order without submitting",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier for this event"
          },
          "eventType": {
            "type": "string",
            "default": "ORDER_SAVED",
            "description": "The type of the event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the event was emitted"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "orderId": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier for this draft order"
          },
          "orderStatus": {
            "type": "string",
            "default": "Draft",
            "description": "The current status of the order (e.g., Draft)"
          },
          "orderType": {
            "type": "string",
            "description": "The type of order (e.g., New, Transfer, Upgrade)"
          },
          "CustomerDetails": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/CustomerDetails"
          },
          "Address": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/Address"
          },
          "serviceAddress": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/Address",
            "description": "The service installation address (alias for Address)"
          },
          "billingAddress": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/billingAddress"
          },
          "Appointment": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/Appointment"
          },
          "lineItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderLineItem"
            }
          }
        },
        "required": ["eventId", "eventType", "eventTimestamp", "orgId", "orderId", "CustomerDetails", "Address"]
      },
      "OrderConfirmedEvent": {
        "type": "object",
        "description": "Event fired when order is validated and accepted for fulfillment",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier for this event"
          },
          "eventType": {
            "type": "string",
            "default": "ORDER_CONFIRMED",
            "description": "The type of the event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the event was emitted"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "orderId": {
            "type": "string",
            "format": "uuid",
            "description": "The unique identifier of the order being confirmed"
          },
          "orderStatus": {
            "type": "string",
            "default": "Confirmed",
            "description": "The current status of the order"
          },
          "confirmationTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the order was confirmed"
          },
          "confirmedBy": {
            "type": "string",
            "description": "Identifier of the user or system that confirmed the order (e.g., 'system-auto')"
          },
          "status": {
            "type": "string",
            "default": "Confirmed",
            "description": "The new status of the order (legacy field, prefer orderStatus)"
          }
        },
        "required": ["eventId", "eventType", "eventTimestamp", "orgId", "orderId", "confirmationTimestamp"]
      },
      "OrderUpdatedEvent": {
        "type": "object",
        "description": "Event fired when an existing unfulfilled order is modified",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier for this event"
          },
          "eventType": {
            "type": "string",
            "default": "ORDER_UPDATED",
            "description": "The type of the event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the event was emitted"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "orderId": {
            "type": "string",
            "format": "uuid",
            "description": "The ID of the order being updated"
          },
          "orderStatus": {
            "type": "string",
            "description": "The current status of the order after update (e.g., Confirmed)"
          },
          "updatedTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp of the update"
          },
          "updatedFields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of field names that were modified in this update (e.g., ['CustomerDetails', 'serviceAddress'])"
          },
          "CustomerDetails": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/CustomerDetails"
          },
          "Address": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/Address"
          },
          "serviceAddress": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/Address",
            "description": "The service installation address (alias for Address)"
          },
          "billingAddress": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/billingAddress"
          },
          "Appointment": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/Appointment"
          },
          "lineItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderLineItem"
            }
          }
        },
        "required": ["eventId", "eventType", "eventTimestamp", "orgId", "orderId", "updatedTimestamp"]
      },
      "OrderCancelledEvent": {
        "type": "object",
        "description": "Event fired when an order is cancelled before fulfillment",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier for this event"
          },
          "eventType": {
            "type": "string",
            "default": "ORDER_CANCELLED",
            "description": "The type of the event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the event was emitted"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "orderId": {
            "type": "string",
            "format": "uuid",
            "description": "The unique identifier of the order being cancelled"
          },
          "orderStatus": {
            "type": "string",
            "default": "Cancelled",
            "description": "The current status of the order"
          },
          "cancellationTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the order was cancelled"
          },
          "reason": {
            "type": "string",
            "description": "The reason for the cancellation"
          },
          "cancelledBy": {
            "type": "string",
            "description": "Identifier of the user or system that cancelled the order (e.g., 'Customer', 'Agent')"
          },
          "refundAmount": {
            "$ref": "#/components/schemas/Price",
            "description": "The refund amount issued upon cancellation, if applicable"
          }
        },
        "required": ["eventId", "eventType", "eventTimestamp", "orgId", "orderId", "cancellationTimestamp", "reason"]
      },
      "OrderRescheduledEvent": {
        "type": "object",
        "description": "Event fired when an installation appointment is rescheduled",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier for this event"
          },
          "eventType": {
            "type": "string",
            "default": "ORDER_RESCHEDULED",
            "description": "The type of the event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the event was emitted"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "orderId": {
            "type": "string",
            "format": "uuid",
            "description": "The unique identifier of the order being rescheduled"
          },
          "orderStatus": {
            "type": "string",
            "default": "Rescheduled",
            "description": "The current status of the order"
          },
          "previousAppointment": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/Appointment",
            "description": "The original appointment that was replaced"
          },
          "newAppointment": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/Appointment",
            "description": "The new appointment replacing the previous one"
          },
          "reason": {
            "type": "string",
            "description": "The reason for rescheduling"
          },
          "rescheduledBy": {
            "type": "string",
            "description": "Identifier of the user or system that rescheduled the appointment (e.g., 'Customer', 'Agent')"
          }
        },
        "required": ["eventId", "eventType", "eventTimestamp", "orgId", "orderId", "previousAppointment", "newAppointment"]
      },
      "OrderInstalledEvent": {
        "type": "object",
        "description": "Event fired when an order installation has been completed by a technician",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier for this event"
          },
          "eventType": {
            "type": "string",
            "default": "ORDER_INSTALLED",
            "description": "The type of the event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the event was emitted"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "orderId": {
            "type": "string",
            "format": "uuid",
            "description": "The unique identifier of the installed order"
          },
          "orderStatus": {
            "type": "string",
            "default": "Installed",
            "description": "The current status of the order"
          },
          "installationCompletedAt": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the physical installation was completed"
          },
          "technicianId": {
            "type": "string",
            "description": "The identifier of the technician who performed the installation"
          },
          "installationNotes": {
            "type": "string",
            "description": "Free-text notes recorded by the technician during installation"
          },
          "installationDurationMinutes": {
            "type": "integer",
            "description": "The total duration of the installation in minutes"
          }
        },
        "required": ["eventId", "eventType", "eventTimestamp", "orgId", "orderId", "installationCompletedAt", "technicianId"]
      }
    }
  },
  "paths": {
    "/events/order-created": {
      "post": {
        "summary": "Order Created Event",
        "description": "Publishes an order creation event to Kafka topic: order-created",
        "tags": ["Order Events"],
        "intent": "Order Management",
        "sub_intent": "Create New Order",
