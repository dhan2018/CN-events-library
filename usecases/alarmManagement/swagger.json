{
  "openapi": "3.0.3",
  "info": {
    "title": "Alarm Management Events API",
    "description": "Event schemas for network alarm lifecycle management in a Kafka-based event-driven system for ISP network operations. Derived from TMF642 Alarm Management v3 (tmforum/TMFAPISWAGGER).",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {
      "AffectedService": {
        "type": "object",
        "description": "A customer service impacted by the alarm condition",
        "properties": {
          "serviceId": {
            "type": "string",
            "description": "Unique identifier of the affected service"
          },
          "serviceType": {
            "type": "string",
            "enum": ["Data", "Voice", "Video", "AddOn"],
            "description": "The type of service affected"
          },
          "serviceName": {
            "type": "string",
            "description": "The name of the affected service (e.g., 'Fiber Internet 1 Gig')"
          }
        },
        "required": ["serviceId", "serviceType", "serviceName"]
      },
      "AlarmRaisedEvent": {
        "type": "object",
        "description": "Event fired when a new network alarm condition is detected by the monitoring system",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this event (for idempotency)"
          },
          "eventType": {
            "type": "string",
            "enum": ["ALARM_RAISED"],
            "default": "ALARM_RAISED",
            "description": "Type of event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when this event occurred"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "alarmId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this alarm within the CN events system"
          },
          "externalAlarmId": {
            "type": "string",
            "description": "The alarm identifier from the originating network management system"
          },
          "alarmType": {
            "type": "string",
            "enum": [
              "communicationsAlarm",
              "equipmentAlarm",
              "environmentalAlarm",
              "integrityViolation",
              "qualityOfServiceAlarm"
            ],
            "description": "The ITU-T alarm category"
          },
          "perceivedSeverity": {
            "type": "string",
            "enum": ["Critical", "Major", "Minor", "Warning", "Indeterminate"],
            "description": "The severity level of the alarm as perceived by the monitoring system"
          },
          "alarmedObjectType": {
            "type": "string",
            "enum": ["Router", "OLT", "ONT", "Switch", "Fiber", "CPE", "DSLAM"],
            "description": "The type of network element that raised the alarm"
          },
          "alarmedObjectId": {
            "type": "string",
            "description": "Identifier of the specific network element that raised the alarm"
          },
          "sourceSystemId": {
            "type": "string",
            "description": "Identifier of the network management system that originated this alarm"
          },
          "alarmDetails": {
            "type": "string",
            "description": "Human-readable description of the alarm condition"
          },
          "alarmRaisedTime": {
            "type": "string",
            "format": "date-time",
            "description": "The time the alarm condition was first detected on the network element"
          },
          "serviceAffecting": {
            "type": "boolean",
            "description": "Indicates whether this alarm is causing a degradation or outage for one or more customer services"
          },
          "affectedServices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AffectedService"
            },
            "description": "List of customer services impacted by this alarm"
          }
        },
        "required": [
          "eventId",
          "eventType",
          "eventTimestamp",
          "orgId",
          "alarmId",
          "externalAlarmId",
          "alarmType",
          "perceivedSeverity",
          "alarmedObjectType",
          "alarmedObjectId",
          "sourceSystemId",
          "alarmRaisedTime",
          "serviceAffecting"
        ]
      },
      "AlarmUpdatedEvent": {
        "type": "object",
        "description": "Event fired when an active alarm's details or severity are revised",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this event (for idempotency)"
          },
          "eventType": {
            "type": "string",
            "enum": ["ALARM_UPDATED"],
            "default": "ALARM_UPDATED",
            "description": "Type of event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when this event occurred"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "alarmId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier of the alarm being updated"
          },
          "alarmChangedTime": {
            "type": "string",
            "format": "date-time",
            "description": "The time the alarm details were last modified"
          },
          "perceivedSeverity": {
            "type": "string",
            "enum": ["Critical", "Major", "Minor", "Warning", "Indeterminate"],
            "description": "The updated severity level of the alarm"
          },
          "alarmDetails": {
            "type": "string",
            "description": "Updated description of the alarm condition"
          },
          "serviceAffecting": {
            "type": "boolean",
            "description": "Updated indicator of whether this alarm affects customer services"
          }
        },
        "required": [
          "eventId",
          "eventType",
          "eventTimestamp",
          "orgId",
          "alarmId",
          "alarmChangedTime",
          "perceivedSeverity",
          "serviceAffecting"
        ]
      },
      "AlarmClearedEvent": {
        "type": "object",
        "description": "Event fired when an alarm condition is resolved and the network element returns to normal operation",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this event (for idempotency)"
          },
          "eventType": {
            "type": "string",
            "enum": ["ALARM_CLEARED"],
            "default": "ALARM_CLEARED",
            "description": "Type of event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when this event occurred"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "alarmId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier of the alarm being cleared"
          },
          "externalAlarmId": {
            "type": "string",
            "description": "The alarm identifier in the originating network management system"
          },
          "alarmClearedTime": {
            "type": "string",
            "format": "date-time",
            "description": "The time the alarm condition was resolved on the network element"
          },
          "clearUserId": {
            "type": "string",
            "description": "Identifier of the operator or system that cleared the alarm"
          },
          "clearReason": {
            "type": "string",
            "description": "Explanation of how the alarm condition was resolved"
          },
          "affectedServices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AffectedService"
            },
            "description": "List of services that were affected and are now restored"
          }
        },
        "required": [
          "eventId",
          "eventType",
          "eventTimestamp",
          "orgId",
          "alarmId",
          "externalAlarmId",
          "alarmClearedTime",
          "clearUserId",
          "clearReason"
        ]
      },
      "AlarmAcknowledgedEvent": {
        "type": "object",
        "description": "Event fired when a network operator acknowledges an active alarm, taking ownership of its investigation",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this event (for idempotency)"
          },
          "eventType": {
            "type": "string",
            "enum": ["ALARM_ACKNOWLEDGED"],
            "default": "ALARM_ACKNOWLEDGED",
            "description": "Type of event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when this event occurred"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "alarmId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier of the alarm being acknowledged"
          },
          "ackState": {
            "type": "string",
            "enum": ["ACKNOWLEDGED", "UNACKNOWLEDGED"],
            "description": "The updated acknowledgment state of the alarm"
          },
          "ackUserId": {
            "type": "string",
            "description": "Identifier of the operator who acknowledged the alarm"
          },
          "ackTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The time the acknowledgment was recorded"
          },
          "alarmDetails": {
            "type": "string",
            "description": "Any additional context or notes added by the acknowledging operator"
          }
        },
        "required": [
          "eventId",
          "eventType",
          "eventTimestamp",
          "orgId",
          "alarmId",
          "ackState",
          "ackUserId",
          "ackTimestamp"
        ]
      }
    }
  },
  "paths": {
    "/events/alarm-raised": {
      "post": {
        "summary": "Alarm Raised Event",
        "description": "Publishes a new network alarm detection event to Kafka topic: alarm-raised",
        "tags": ["Alarm Events"],
        "intent": "Alarm Management",
        "sub_intent": "Raise Network Alarm",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AlarmRaisedEvent"
              },
              "sample_event": {
                "eventId": "e3f4a5b6-c7d8-9012-efab-cd3456789012",
                "eventType": "ALARM_RAISED",
                "eventTimestamp": "2024-05-10T02:14:33Z",
                "orgId": "ORG-001",
                "alarmId": "a50e8400-e29b-41d4-a716-446655440030",
                "externalAlarmId": "NMS-ALM-20240510-00447",
                "alarmType": "equipmentAlarm",
                "perceivedSeverity": "Major",
                "alarmedObjectType": "OLT",
                "alarmedObjectId": "OLT-AUSTIN-EAST-03",
                "sourceSystemId": "NMS-CISCO-PROD",
                "alarmDetails": "OLT card in slot 4 reporting loss of signal on 12 downstream ports — potential fiber cut or card failure",
                "alarmRaisedTime": "2024-05-10T02:14:15Z",
                "serviceAffecting": true,
                "affectedServices": [
                  {
                    "serviceId": "SVC-88123",
                    "serviceType": "Data",
                    "serviceName": "Fiber Internet 1 Gig"
                  },
                  {
                    "serviceId": "SVC-88124",
                    "serviceType": "Voice",
                    "serviceName": "Home Phone Service"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Event accepted for processing"
          }
        }
      }
    },
    "/events/alarm-updated": {
      "post": {
        "summary": "Alarm Updated Event",
        "description": "Publishes an alarm details change event to Kafka topic: alarm-updated",
        "tags": ["Alarm Events"],
        "intent": "Alarm Management",
        "sub_intent": "Update Active Alarm",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AlarmUpdatedEvent"
              },
              "sample_event": {
                "eventId": "f4a5b6c7-d8e9-0123-fabc-de4567890123",
                "eventType": "ALARM_UPDATED",
                "eventTimestamp": "2024-05-10T02:30:00Z",
                "orgId": "ORG-001",
                "alarmId": "a50e8400-e29b-41d4-a716-446655440030",
                "alarmChangedTime": "2024-05-10T02:30:00Z",
                "perceivedSeverity": "Critical",
                "alarmDetails": "Confirmed fiber cut on feeder cable segment F-EAST-07 — affecting 47 downstream ONTs across 3 distribution areas",
                "serviceAffecting": true
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Event accepted for processing"
          }
        }
      }
    },
    "/events/alarm-cleared": {
      "post": {
        "summary": "Alarm Cleared Event",
        "description": "Publishes a network alarm resolution event to Kafka topic: alarm-cleared",
        "tags": ["Alarm Events"],
        "intent": "Alarm Management",
        "sub_intent": "Clear Network Alarm",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AlarmClearedEvent"
              },
              "sample_event": {
                "eventId": "a5b6c7d8-e9f0-1234-abcd-ef5678901234",
                "eventType": "ALARM_CLEARED",
                "eventTimestamp": "2024-05-10T06:52:00Z",
                "orgId": "ORG-001",
                "alarmId": "a50e8400-e29b-41d4-a716-446655440030",
                "externalAlarmId": "NMS-ALM-20240510-00447",
                "alarmClearedTime": "2024-05-10T06:50:00Z",
                "clearUserId": "NOC-TECH-042",
                "clearReason": "Fiber splice restored on segment F-EAST-07 — all 47 ONTs confirmed online, services restored",
                "affectedServices": [
                  {
                    "serviceId": "SVC-88123",
                    "serviceType": "Data",
                    "serviceName": "Fiber Internet 1 Gig"
                  },
                  {
                    "serviceId": "SVC-88124",
                    "serviceType": "Voice",
                    "serviceName": "Home Phone Service"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Event accepted for processing"
          }
        }
      }
    },
    "/events/alarm-acknowledged": {
      "post": {
        "summary": "Alarm Acknowledged Event",
        "description": "Publishes an alarm acknowledgment event to Kafka topic: alarm-acknowledged",
        "tags": ["Alarm Events"],
        "intent": "Alarm Management",
        "sub_intent": "Acknowledge Network Alarm",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AlarmAcknowledgedEvent"
              },
              "sample_event": {
                "eventId": "b6c7d8e9-f0a1-2345-bcde-fa6789012345",
                "eventType": "ALARM_ACKNOWLEDGED",
                "eventTimestamp": "2024-05-10T02:18:00Z",
                "orgId": "ORG-001",
                "alarmId": "a50e8400-e29b-41d4-a716-446655440030",
                "ackState": "ACKNOWLEDGED",
                "ackUserId": "NOC-TECH-042",
                "ackTimestamp": "2024-05-10T02:18:00Z",
                "alarmDetails": "Investigating — dispatching field crew to check fiber route F-EAST-07"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Event accepted for processing"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Alarm Events",
      "description": "Events related to network alarm lifecycle management for ISP network operations"
    }
  ]
}