{
  "openapi": "3.0.3",
  "info": {
    "title": "Billing Management Events API",
    "description": "Event schemas for customer bill lifecycle management in a Kafka-based event-driven system for ISP services. Derived from TMF678 v4.0.",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {
      "BillAmount": {
        "type": "object",
        "description": "Monetary amount with currency",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The numeric value of the monetary amount"
          },
          "currency": {
            "type": "string",
            "default": "USD",
            "description": "The currency code (e.g., USD)"
          }
        },
        "required": ["amount", "currency"]
      },
      "BillingPeriod": {
        "type": "object",
        "description": "The billing cycle period covered by a customer bill",
        "properties": {
          "startDate": {
            "type": "string",
            "format": "date",
            "description": "First day of the billing period"
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "description": "Last day of the billing period"
          }
        },
        "required": ["startDate", "endDate"]
      },
      "BillCreatedEvent": {
        "type": "object",
        "description": "Event fired when a new customer bill is generated at the end of a billing cycle",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this event (for idempotency)"
          },
          "eventType": {
            "type": "string",
            "enum": ["BILL_CREATED"],
            "default": "BILL_CREATED",
            "description": "Type of event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when this event occurred"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "billId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this bill"
          },
          "billNo": {
            "type": "string",
            "description": "Human-readable bill reference number (e.g., BILL-2024-00123)"
          },
          "customerId": {
            "type": "string",
            "description": "Identifier of the customer this bill belongs to"
          },
          "billingAccountId": {
            "type": "string",
            "description": "Identifier of the billing account associated with this bill"
          },
          "billDate": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the bill was generated"
          },
          "paymentDueDate": {
            "type": "string",
            "format": "date-time",
            "description": "The deadline by which payment must be received"
          },
          "billingPeriod": {
            "$ref": "#/components/schemas/BillingPeriod"
          },
          "amountDue": {
            "$ref": "#/components/schemas/BillAmount"
          },
          "taxIncludedAmount": {
            "$ref": "#/components/schemas/BillAmount"
          },
          "CustomerDetails": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/CustomerDetails"
          },
          "billingAddress": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/billingAddress"
          }
        },
        "required": [
          "eventId",
          "eventType",
          "eventTimestamp",
          "orgId",
          "billId",
          "billNo",
          "customerId",
          "billingAccountId",
          "billDate",
          "paymentDueDate",
          "billingPeriod",
          "amountDue",
          "taxIncludedAmount",
          "CustomerDetails",
          "billingAddress"
        ]
      },
      "BillSentEvent": {
        "type": "object",
        "description": "Event fired when a bill is dispatched to the customer via their preferred delivery channel",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this event (for idempotency)"
          },
          "eventType": {
            "type": "string",
            "enum": ["BILL_SENT"],
            "default": "BILL_SENT",
            "description": "Type of event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when this event occurred"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "billId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the bill that was sent"
          },
          "billNo": {
            "type": "string",
            "description": "Human-readable bill reference number"
          },
          "customerId": {
            "type": "string",
            "description": "Identifier of the customer receiving the bill"
          },
          "sentTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the bill was dispatched"
          },
          "deliveryChannel": {
            "type": "string",
            "enum": ["Email", "SMS", "Portal", "Post"],
            "description": "The channel through which the bill was delivered"
          },
          "CustomerDetails": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/CustomerDetails"
          }
        },
        "required": [
          "eventId",
          "eventType",
          "eventTimestamp",
          "orgId",
          "billId",
          "billNo",
          "customerId",
          "sentTimestamp",
          "deliveryChannel",
          "CustomerDetails"
        ]
      },
      "BillPaymentReceivedEvent": {
        "type": "object",
        "description": "Event fired when a payment is received against an outstanding bill",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this event (for idempotency)"
          },
          "eventType": {
            "type": "string",
            "enum": ["BILL_PAYMENT_RECEIVED"],
            "default": "BILL_PAYMENT_RECEIVED",
            "description": "Type of event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when this event occurred"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "billId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier of the bill being paid"
          },
          "billNo": {
            "type": "string",
            "description": "Human-readable bill reference number"
          },
          "customerId": {
            "type": "string",
            "description": "Identifier of the customer making the payment"
          },
          "paymentTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the payment was recorded"
          },
          "paymentMethod": {
            "type": "string",
            "enum": ["CreditCard", "DebitCard", "BankTransfer", "AutoPay", "Check", "Cash"],
            "description": "The payment method used"
          },
          "amountPaid": {
            "$ref": "#/components/schemas/BillAmount"
          },
          "remainingBalance": {
            "$ref": "#/components/schemas/BillAmount"
          },
          "CustomerDetails": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/CustomerDetails"
          }
        },
        "required": [
          "eventId",
          "eventType",
          "eventTimestamp",
          "orgId",
          "billId",
          "billNo",
          "customerId",
          "paymentTimestamp",
          "paymentMethod",
          "amountPaid",
          "remainingBalance",
          "CustomerDetails"
        ]
      },
      "BillOverdueEvent": {
        "type": "object",
        "description": "Event fired when a bill has passed its payment due date without full payment",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this event (for idempotency)"
          },
          "eventType": {
            "type": "string",
            "enum": ["BILL_OVERDUE"],
            "default": "BILL_OVERDUE",
            "description": "Type of event"
          },
          "eventTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when this event occurred"
          },
          "orgId": {
            "type": "string",
            "description": "Identifier of the organization/tenant"
          },
          "billId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier of the overdue bill"
          },
          "billNo": {
            "type": "string",
            "description": "Human-readable bill reference number"
          },
          "customerId": {
            "type": "string",
            "description": "Identifier of the customer with the overdue bill"
          },
          "paymentDueDate": {
            "type": "string",
            "format": "date-time",
            "description": "The original payment deadline that was missed"
          },
          "overdueSinceDate": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the bill became overdue"
          },
          "amountDue": {
            "$ref": "#/components/schemas/BillAmount"
          },
          "CustomerDetails": {
            "$ref": "../../reusableComponents/swagger.json#/components/schemas/CustomerDetails"
          }
        },
        "required": [
          "eventId",
          "eventType",
          "eventTimestamp",
          "orgId",
          "billId",
          "billNo",
          "customerId",
          "paymentDueDate",
          "overdueSinceDate",
          "amountDue",
          "CustomerDetails"
        ]
      }
    }
  },
  "paths": {
    "/events/bill-created": {
      "post": {
        "summary": "Bill Created Event",
        "description": "Publishes a bill generation event to Kafka topic: bill-created",
        "tags": ["Billing Events"],
        "intent": "Billing Management",
        "sub_intent": "Generate Customer Bill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BillCreatedEvent"
              },
              "sample_event": {
                "eventId": "e5f6a7b8-c9d0-1234-efab-cd5678901234",
                "eventType": "BILL_CREATED",
                "eventTimestamp": "2024-02-01T00:05:00Z",
                "orgId": "ORG-001",
                "billId": "750e8400-e29b-41d4-a716-446655440002",
                "billNo": "BILL-2024-00456",
                "customerId": "CUST-12345",
                "billingAccountId": "BILLACC-001",
                "billDate": "2024-02-01T00:05:00Z",
                "paymentDueDate": "2024-02-20T23:59:59Z",
                "billingPeriod": {
                  "startDate": "2024-01-01",
                  "endDate": "2024-01-31"
                },
                "amountDue": {
                  "amount": 89.99,
                  "currency": "USD"
                },
                "taxIncludedAmount": {
                  "amount": 97.19,
                  "currency": "USD"
                },
                "CustomerDetails": {
                  "id": "CUSTDET-001",
                  "orgId": "ORG-001",
                  "fullName": "John Smith",
                  "email": "john.smith@email.com",
                  "mobileNumber": "+1-555-123-4567"
                },
                "billingAddress": {
                  "id": "BILLADDR-001",
                  "orgId": "ORG-001",
                  "street": "123 Main St",
                  "city": "Springfield",
                  "state": "IL",
                  "zipCode": "62701"
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Event accepted for processing"
          }
        }
      }
    },
    "/events/bill-sent": {
      "post": {
        "summary": "Bill Sent Event",
        "description": "Publishes a bill delivery event to Kafka topic: bill-sent",
        "tags": ["Billing Events"],
        "intent": "Billing Management",
        "sub_intent": "Send Bill to Customer",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BillSentEvent"
              },
              "sample_event": {
                "eventId": "f6a7b8c9-d0e1-2345-fabc-de6789012345",
                "eventType": "BILL_SENT",
                "eventTimestamp": "2024-02-01T06:00:00Z",
                "orgId": "ORG-001",
                "billId": "750e8400-e29b-41d4-a716-446655440002",
                "billNo": "BILL-2024-00456",
                "customerId": "CUST-12345",
                "sentTimestamp": "2024-02-01T06:00:00Z",
                "deliveryChannel": "Email",
                "CustomerDetails": {
                  "id": "CUSTDET-001",
                  "orgId": "ORG-001",
                  "fullName": "John Smith",
                  "email": "john.smith@email.com",
                  "mobileNumber": "+1-555-123-4567"
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Event accepted for processing"
          }
        }
      }
    },
    "/events/bill-payment-received": {
      "post": {
        "summary": "Bill Payment Received Event",
        "description": "Publishes a bill payment event to Kafka topic: bill-payment-received",
        "tags": ["Billing Events"],
        "intent": "Billing Management",
        "sub_intent": "Record Bill Payment",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BillPaymentReceivedEvent"
              },
              "sample_event": {
                "eventId": "a7b8c9d0-e1f2-3456-abcd-ef7890123456",
                "eventType": "BILL_PAYMENT_RECEIVED",
                "eventTimestamp": "2024-02-15T10:30:00Z",
                "orgId": "ORG-001",
                "billId": "750e8400-e29b-41d4-a716-446655440002",
                "billNo": "BILL-2024-00456",
                "customerId": "CUST-12345",
                "paymentTimestamp": "2024-02-15T10:30:00Z",
                "paymentMethod": "AutoPay",
                "amountPaid": {
                  "amount": 97.19,
                  "currency": "USD"
                },
                "remainingBalance": {
                  "amount": 0.00,
                  "currency": "USD"
                },
                "CustomerDetails": {
                  "id": "CUSTDET-001",
                  "orgId": "ORG-001",
                  "fullName": "John Smith",
                  "email": "john.smith@email.com",
                  "mobileNumber": "+1-555-123-4567"
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Event accepted for processing"
          }
        }
      }
    },
    "/events/bill-overdue": {
      "post": {
        "summary": "Bill Overdue Event",
        "description": "Publishes a bill overdue alert event to Kafka topic: bill-overdue",
        "tags": ["Billing Events"],
        "intent": "Billing Management",
        "sub_intent": "Flag Overdue Bill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BillOverdueEvent"
              },
              "sample_event": {
                "eventId": "b8c9d0e1-f2a3-4567-bcde-fa8901234567",
                "eventType": "BILL_OVERDUE",
                "eventTimestamp": "2024-02-21T00:01:00Z",
                "orgId": "ORG-001",
                "billId": "850e8400-e29b-41d4-a716-446655440003",
                "billNo": "BILL-2024-00389",
                "customerId": "CUST-67890",
                "paymentDueDate": "2024-02-20T23:59:59Z",
                "overdueSinceDate": "2024-02-21T00:00:00Z",
                "amountDue": {
                  "amount": 110.45,
                  "currency": "USD"
                },
                "CustomerDetails": {
                  "id": "CUSTDET-002",
                  "orgId": "ORG-001",
                  "fullName": "Jane Doe",
                  "email": "jane.doe@email.com",
                  "mobileNumber": "+1-555-987-6543"
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Event accepted for processing"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Billing Events",
      "description": "Events related to customer bill lifecycle management"
    }
  ]
}
